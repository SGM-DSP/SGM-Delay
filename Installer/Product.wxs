<?xml version="1.0" encoding="UTF-8"?>
<Wix
  xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="SGM Delay"
    Manufacturer="Sagami"
    Version="$(var.ProductVersion)"
    UpgradeCode="4a2719dd-7ab6-4af6-87c1-4420ee7d35bc"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of SGM Delay is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="VST3Folder" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectRoot)\Installer\License.rtf" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="CompanyFolder" Name="Sagami">
        <Directory Id="AppInstallFolder" Name="SGM Delay">
          <Component Id="StandaloneComponent" Guid="d85264bf-79b4-43ac-8f79-e9c214fa10a1">
            <File
              Id="StandaloneExe"
              Source="$(var.BuildOutput)\Standalone\SGM Delay.exe"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonFiles64Folder">
      <Directory Id="VST3Folder" Name="VST3">
        <Directory Id="PluginBundleFolder" Name="SGM Delay.vst3">
          <Directory Id="PluginContentsFolder" Name="Contents">
            <Directory Id="PluginResourcesFolder" Name="Resources">
              <Component Id="Vst3ModuleInfoComponent" Guid="6ccbc512-1708-4058-8c4e-a8c438cb1ffc">
                <File
                  Id="Vst3ModuleInfo"
                  Source="$(var.BuildOutput)\VST3\SGM Delay.vst3\Contents\Resources\moduleinfo.json"
                  KeyPath="yes" />
              </Component>
            </Directory>

            <Directory Id="PluginBinaryFolder" Name="x86_64-win">
              <Component Id="Vst3BinaryComponent" Guid="226dbe11-c90e-45b6-a180-5c99bc5717c9">
                <File
                  Id="Vst3Binary"
                  Source="$(var.BuildOutput)\VST3\SGM Delay.vst3\Contents\x86_64-win\SGM Delay.vst3"
                  KeyPath="yes" />
              </Component>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="SGM Delay" Level="1">
      <ComponentRef Id="StandaloneComponent" />
      <ComponentRef Id="Vst3ModuleInfoComponent" />
      <ComponentRef Id="Vst3BinaryComponent" />
    </Feature>
  </Package>
</Wix>
